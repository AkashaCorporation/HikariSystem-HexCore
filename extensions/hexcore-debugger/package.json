{
	"name": "hexcore-debugger",
	"displayName": "HexCore Debugger",
	"description": "Dynamic analysis debugger integration for WinDbg and GDB",
	"version": "1.0.0",
	"publisher": "hikarisystem",
	"license": "MIT",
	"engines": {
		"vscode": "^1.70.0"
	},
	"categories": [
		"Debuggers",
		"Testing"
	],
	"keywords": [
		"debugger",
		"dynamic analysis",
		"windbg",
		"gdb",
		"runtime analysis",
		"api tracing"
	],
	"activationEvents": [
		"onCommand:hexcore.debug.start",
		"onCommand:hexcore.debug.attach",
		"onView:hexcore.debugger.view"
	],
	"main": "./out/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "hexcore.debug.start",
				"title": "Debug: Start Analysis",
				"category": "HexCore Debugger",
				"icon": "$(debug-start)"
			},
			{
				"command": "hexcore.debug.attach",
				"title": "Debug: Attach to Process",
				"category": "HexCore Debugger",
				"icon": "$(debug-connect)"
			},
			{
				"command": "hexcore.debug.breakpoint",
				"title": "Toggle Breakpoint",
				"category": "HexCore Debugger",
				"icon": "$(debug-breakpoint)"
			},
			{
				"command": "hexcore.debug.stepInto",
				"title": "Step Into",
				"category": "HexCore Debugger",
				"icon": "$(debug-step-into)"
			},
			{
				"command": "hexcore.debug.stepOver",
				"title": "Step Over",
				"category": "HexCore Debugger",
				"icon": "$(debug-step-over)"
			},
			{
				"command": "hexcore.debug.continue",
				"title": "Continue",
				"category": "HexCore Debugger",
				"icon": "$(debug-continue)"
			},
			{
				"command": "hexcore.debug.readMemory",
				"title": "Read Memory",
				"category": "HexCore Debugger"
			},
			{
				"command": "hexcore.debug.setRegister",
				"title": "Set Register",
				"category": "HexCore Debugger"
			},
			{
				"command": "hexcore.debug.traceAPI",
				"title": "Enable API Tracing",
				"category": "HexCore Debugger"
			}
		],
		"viewsContainers": {
			"activitybar": [
				{
					"id": "hexcore-debugger",
					"title": "Debugger",
					"icon": "$(debug-alt)"
				}
			]
		},
		"views": {
			"hexcore-debugger": [
				{
					"type": "webview",
					"id": "hexcore.debugger.view",
					"name": "Debug Session"
				},
				{
					"type": "tree",
					"id": "hexcore.debugger.registers",
					"name": "Registers"
				},
				{
					"type": "tree",
					"id": "hexcore.debugger.memory",
					"name": "Memory"
				},
				{
					"type": "tree",
					"id": "hexcore.debugger.stack",
					"name": "Stack"
				}
			]
		},
		"configuration": {
			"title": "HexCore Debugger",
			"properties": {
				"hexcore.debugger.backend": {
					"type": "string",
					"default": "auto",
					"enum": ["auto", "windbg", "gdb", "lldb"],
					"description": "Debugger backend to use"
				},
				"hexcore.debugger.windbgPath": {
					"type": "string",
					"default": "",
					"description": "Path to WinDbg executable"
				},
				"hexcore.debugger.gdbPath": {
					"type": "string",
					"default": "gdb",
					"description": "Path to GDB executable"
				}
			}
		}
	},
	"scripts": {
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./"
	},
	"devDependencies": {
		"@types/node": "^18.0.0",
		"@types/vscode": "^1.70.0",
		"typescript": "^5.0.0"
	}
}
