{
	"compilerOptions": {
		"module": "commonjs",
		"target": "ES2020",
		"lib": ["ES2020"],
		"outDir": "out",
		"rootDir": "src",
		"sourceMap": true,
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"baseUrl": ".",
		"paths": {
			"hexcore-capstone": ["../hexcore-capstone"],
			"hexcore-remill": ["../hexcore-remill"],
			"hexcore-rellic": ["../hexcore-rellic"]
		}
	},
	"exclude": ["node_modules", ".vscode-test"]
}
